# ── Grype Configuration ─────────────────────────────────────────
# Copy this file to .env and adjust values as needed.

# ── Database Cache ───────────────────────────────────────────────
# Directory for vulnerability database cache
GRYPE_DB_CACHE_DIR=/root/.cache/grype/db

# ── Database Updates ─────────────────────────────────────────────
# Auto-update vulnerability database before scanning (default: true)
GRYPE_DB_AUTO_UPDATE=true

# ── Update Checks ────────────────────────────────────────────────
# Check for newer Grype version (default: false)
GRYPE_CHECK_FOR_APP_UPDATE=false

# ── Output Format ────────────────────────────────────────────────
# Report format: table, json, cyclonedx, template
GRYPE_OUTPUT=table

# ── Fail-on Severity ─────────────────────────────────────────────
# Exit with code 1 if vulnerabilities at or above this severity are found
# Options: negligible, low, medium, high, critical
GRYPE_FAIL_ON_SEVERITY=critical
