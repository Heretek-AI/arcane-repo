# ── PyTorch Serve Configuration ───────────────────────────────────
# Copy this file to .env and adjust values as needed.

# ── Ports ─────────────────────────────────────────────────────────
# Inference API host port (default: 8080)
TORCHSERVE_INFERENCE_PORT=8080

# Management API host port (default: 8081)
TORCHSERVE_MANAGEMENT_PORT=8081

# ── Models ────────────────────────────────────────────────────────
# Comma-separated model names to load on startup (default: all)
TORCHSERVE_MODELS=all

# ── Service Envelope ──────────────────────────────────────────────
# Response enveloping: body, json, recordio
TS_SERVICE_ENVELOPE=body
