# ── DocsGPT Configuration ──────────────────────────────────────────
# Copy this file to .env and adjust values as needed.

# ── ⚠️  REQUIRED ⚠️  ──────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=change-me-to-a-random-64-char-hex-string

# Database password (required)
DOCSGPT_DB_PASSWORD=change-me-to-a-strong-password

# ── Ports ─────────────────────────────────────────────────────────
# DocsGPT application port (default: 3000)
DOCSGPT_PORT=3000

# Host port for PostgreSQL (default: 5432)
DOCSGPT_DB_PORT=5432

# ── Database ───────────────────────────────────────────────────────
DOCSGPT_DB_USER=docsgpt
DOCSGPT_DB_NAME=docsgpt

# ── LLM Configuration ─────────────────────────────────────────────
# Primary LLM provider (e.g., gpt-4o, gpt-4-turbo)
LLM_NAME=gpt-4o

# OpenAI API key (required for OpenAI models)
OPENAI_API_KEY=

# For local inference via Ollama
OLLAMA_BASE_URL=http://host.docker.internal:11434

# ── Embeddings (Optional) ─────────────────────────────────────────
# Override default embedding provider if needed
EMBEDDINGS_NAME=
EMBEDDINGS_KEY=

# ── Application ────────────────────────────────────────────────────
APP_ENV=production
