# ── Ory Hydra OAuth2 / OIDC Provider ──────────────────────────────────
# 17,000+ ★ | ory/hydra

# ── PostgreSQL ───────────────────────────────────────────────────────
POSTGRES_USER=hydra
POSTGRES_PASSWORD=changeme
POSTGRES_DB=hydra
POSTGRES_PORT=5433

# ── Hydra Service Ports ──────────────────────────────────────────────
HYDRA_PUBLIC_PORT=4444
HYDRA_ADMIN_PORT=4445

# ── Hydra Configuration ──────────────────────────────────────────────
HYDRA_ISSUER_URL=http://localhost:4444
HYDRA_CONSENT_URL=http://localhost:3000/consent
HYDRA_LOGIN_URL=http://localhost:3000/login
HYDRA_LOGOUT_URL=http://localhost:3000/logout
HYDRA_LOG_LEVEL=info

# ── Secrets ───────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
SECRETS_SYSTEM=changeme-generate-a-real-secret
