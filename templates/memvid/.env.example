# ── Memvid Configuration ──────────────────────────────────────────
# Copy this file to .env and adjust values as needed.

# ⚠️  LLM API KEY — OPTIONAL ⚠️
# Required only for cloud embedding support (api_embed feature)
# Get an OpenAI API key at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Host port to expose the Memvid API on (default: 8000)
MEMVID_PORT=8000

# Directory for memory file storage (default: /app/data)
MEMVID_DATA_DIR=/app/data

# Default memory file name (default: default.mv2)
MEMVID_FILE=default.mv2

# Embedding mode: local (ONNX) or api (requires OPENAI_API_KEY)
MEMVID_EMBED_MODE=local

# Log level: info, debug, warn, error
MEMVID_LOG_LEVEL=info
