# ── Ory Hydra OAuth2/OIDC Provider Configuration ────────────────────
# Copy this file to .env and adjust values as needed.

# ── ⚠️  REQUIRED SECRETS ⚠️  ────────────────────────────────────────
#
# SECRETS_SYSTEM: Used to encrypt internal state and OAuth2 tokens.
# Generate before first run:
#   openssl rand -hex 32
#
# POSTGRES_PASSWORD: PostgreSQL superuser password.
#
# Both MUST be set before first run. Changing SECRETS_SYSTEM after
# Hydra has been used invalidates all existing tokens and sessions.

SECRETS_SYSTEM=change-me-to-a-random-64-character-hex-string
POSTGRES_PASSWORD=change-me-to-a-strong-password

# ── Database ────────────────────────────────────────────────────────────
# PostgreSQL user (default: hydra)
POSTGRES_USER=hydra

# PostgreSQL database name (default: hydra)
POSTGRES_DB=hydra

# Host port for PostgreSQL (default: 5433 — offset to avoid conflicts)
POSTGRES_PORT=5433

# ── Hydra Server ────────────────────────────────────────────────────────
# Public-facing API port (default: 4444)
HYDRA_PUBLIC_PORT=4444

# Admin API port — keep internal or protect with a reverse proxy
# (default: 4445)
HYDRA_ADMIN_PORT=4445

# ── URLs ────────────────────────────────────────────────────────────────
# Issuer URL — the public base URL of this Hydra instance.
# Set to your domain in production:
#   HYDRA_ISSUER_URL=https://auth.example.com
HYDRA_ISSUER_URL=http://localhost:4444

# Consent / login / logout pages — points to your custom UI app:
HYDRA_CONSENT_URL=http://localhost:3000/consent
HYDRA_LOGIN_URL=http://localhost:3000/login
HYDRA_LOGOUT_URL=http://localhost:3000/logout

# ── Logging ─────────────────────────────────────────────────────────────
# Log level: panic, fatal, error, warn, info, debug, trace
HYDRA_LOG_LEVEL=info
