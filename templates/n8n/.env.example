# ── n8n Configuration ──────────────────────────────────────────────────
# Copy this file to .env and adjust values as needed.

# ── ⚠️  ENCRYPTION KEY — CRITICAL ⚠️  ──────────────────────────────────
# N8N_ENCRYPTION_KEY encrypts ALL stored credentials — database
# connections, API keys, OAuth tokens, and other secrets saved through
# the n8n editor. If this value changes after credentials exist,
# they become permanently UNRECOVERABLE.
#
# Generate a strong key BEFORE first run:
#   openssl rand -hex 32   # or any 64-character hex string
#
# Set it here and NEVER change it for the same n8n instance.
N8N_ENCRYPTION_KEY=change-me-to-a-random-64-char-hex-string

# Port to expose the n8n web UI and API on (default: 5678)
N8N_PORT=5678

# Protocol used for webhook URLs (http or https)
# Set to https if behind a reverse proxy with TLS termination
N8N_PROTOCOL=http

# Public hostname or IP where n8n is reachable
# Required for incoming webhooks from external services
# Example: n8n.example.com or 192.168.1.100
N8N_HOST=localhost

# Full webhook URL override (optional)
# If set, takes precedence over N8N_PROTOCOL + N8N_HOST
# Example: https://n8n.example.com/
N8N_WEBHOOK_URL=

# ── Basic Authentication ──────────────────────────────────────────────
# Enable to protect the n8n editor with a username and password.
# Set to true and configure credentials below.
N8N_BASIC_AUTH_ACTIVE=false
N8N_BASIC_AUTH_USER=
N8N_BASIC_AUTH_PASSWORD=
