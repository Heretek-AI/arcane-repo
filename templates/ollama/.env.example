# ── Ollama Configuration ──────────────────────────────────────────────────
# Copy this file to .env and adjust values as needed.

# Host port to expose the Ollama API on (default: 11434)
OLLAMA_HOST_PORT=11434

# Default model to pull on first run (use "ollama pull <name>" to add more)
OLLAMA_MODEL=llama3.1:8b

# How long to keep loaded models in memory after last use (default: 5m)
# Set to "0" to unload immediately, or "-1" to keep loaded indefinitely
OLLAMA_KEEP_ALIVE=5m

# Maximum number of parallel request-processing threads (default: 1)
OLLAMA_NUM_PARALLEL=1

# Maximum number of loaded models to keep in memory (default: 1)
OLLAMA_MAX_LOADED_MODELS=1
