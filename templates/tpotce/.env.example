# ── T-Pot Multi-Honeypot Platform Configuration ─────────────────────
# Copy this file to .env and adjust values as needed.

# ── ⚠️  WEB PASSWORD — REQUIRED ⚠️  ───────────────────────────────────
# Password for the T-Pot management web UI (user: admin)
# Must be set before first run.
TPOT_WEB_PW=change-me-to-a-strong-password

# ── External IP ─────────────────────────────────────────────────────────
# External / public IP of this host. Used by the management UI for links
# and by honeypot services to identify attack destinations.
TPOT_EXTIP=0.0.0.0

# ── Ports ───────────────────────────────────────────────────────────────
# SSH honeypot port (default: 2222)
COWRIE_SSH_PORT=2222

# Telnet honeypot port (default: 2323)
COWRIE_TELNET_PORT=2323

# Elasticsearch honeypot port (default: 9200)
ELASTICPOT_PORT=9200

# T-Pot management web UI port (default: 64297)
TPOT_UI_PORT=64297

# T-Pot web dashboard port (default: 64294)
TPOT_WEB_PORT=64294

# ── Optional Services ───────────────────────────────────────────────────
# T-Pot supports additional honeypot services not included in this
# simplified deployment. See README.md for details on adding:
#   - adbhoney (Android Debug Bridge honeypot)
#   - citrixhoneypot (Citrix CVE honeypot)
#   - ddospot (DDoS honeypot)
#   - dicompot (DICOM medical device honeypot)
#   - fatt (File Analysis Tool)
#   - heralding (credential catcher)
#   - mailoney (SMTP honeypot)
#   - medpot (HL7/FHIR medical honeypot)
#   - p0f (passive OS fingerprinting)
#   - redishoneypot (Redis honeypot)
#   - sentrypeer (VoIP fraud detection)
#   - spidertrap (web spider honeypot)
#   - suricata (network IDS engine)

# ── T-Pot Version ───────────────────────────────────────────────────
# Tag for the dtagdevsec/tpotce management UI image (default: latest)
TPOTCE_VERSION=latest

# ── Web UI Credentials ───────────────────────────────────────────────
# Web UI username (default: admin)
TPOT_WEB_USER=admin
