# ── CasaOS Configuration ──────────────────────────────────────────
# Copy this file to .env and adjust values as needed.
#
# IMPORTANT: CasaOS is a host-level daemon — NOT deployable via
# docker compose up. This template provides an informational API
# stub that documents what CasaOS is and how to install it.
#
# To install CasaOS on your host OS:
#   curl -fsSL https://get.casaos.io | sudo bash
#
# See README.md for full installation instructions.

# Informational API port (default: 8000)
CASAOS_PORT=8000
