# ── Sentry (Self-Hosted) Configuration ────────────────────────────
# Copy this file to .env and populate required values.
#
# IMPORTANT: You MUST run the official install.sh FIRST.
#    git clone https://github.com/getsentry/self-hosted.git
#    cd self-hosted && ./install.sh
#
# install.sh handles:
#   - SENTRY_SECRET_KEY generation
#   - Database migrations
#   - Initial admin user creation
#   - Volume initialization
#
# This .env covers the reference core compose AFTER install.sh.
# See README.md for full details and upstream docs link.

# ── Required: PostgreSQL ─────────────────────────────────────────
SENTRY_PG_USER=sentry
SENTRY_PG_PASSWORD=
SENTRY_PG_DB=sentry

# ── Required: ClickHouse ─────────────────────────────────────────
SENTRY_CH_USER=sentry
SENTRY_CH_PASSWORD=
SENTRY_CH_DB=sentry

# ── Required: Sentry Secret ─────────────────────────────────────
# Generated by install.sh — copy from the real .env after setup
SENTRY_SECRET_KEY=

# ── Optional: Kafka ──────────────────────────────────────────────
SENTRY_KAFKA_CLUSTER_ID=sentry-selfhosted-cluster
SENTRY_KAFKA_PORT=9092
SENTRY_KAFKA_ADVERTISED_HOST=localhost

# ── Optional: Ports ─────────────────────────────────────────────
SENTRY_WEB_PORT=9000
SENTRY_NGINX_PORT=80

# ── Optional: Runtime Tuning ─────────────────────────────────────
SENTRY_SERVER_EMAIL=sentry@localhost
SENTRY_EMAIL_HOST=smtp
SENTRY_EVENT_RETENTION_DAYS=90
SENTRY_SINGLE_ORG=true
