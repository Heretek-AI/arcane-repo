# ── RD-Agent Configuration ─────────────────────────────────────────────
# Copy this file to .env and adjust values as needed.

# ── ⚠️  LLM API KEY — REQUIRED ⚠️  ──────────────────────────────────
# RD-Agent requires an LLM provider to drive the R&D process.
# Get an OpenAI API key at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# LLM model for driving R&D (default: gpt-4o)
OPENAI_MODEL=gpt-4o

# Host port to expose the RD-Agent API on (default: 8000)
RDAGENT_PORT=8000
