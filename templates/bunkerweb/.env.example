# ── BunkerWeb Configuration ─────────────────────────────────────
# Copy this file to .env and adjust values as needed.

# ── Ports ────────────────────────────────────────────────────────
# Host ports for HTTP, HTTPS, and optional web UI
BW_HTTP_PORT=80
BW_HTTPS_PORT=443

# ── Server ───────────────────────────────────────────────────────
# Domain name for your server (required for Let's Encrypt)
BW_SERVER_NAME=www.example.com

# ── Let's Encrypt ────────────────────────────────────────────────
# Enable automatic SSL certificate issuance (requires valid domain)
BW_AUTO_LETS_ENCRYPT=no

# ── Reverse Proxy ────────────────────────────────────────────────
# Enable reverse proxy mode to protect a backend application
BW_USE_REVERSE_PROXY=no
BW_REVERSE_PROXY_URL=/
BW_REVERSE_PROXY_HOST=http://app:3000

# ── WAF ──────────────────────────────────────────────────────────
# Enable ModSecurity Web Application Firewall
BW_USE_MODSECURITY=yes
BW_USE_MODSECURITY_CRS=yes

# ── Antibot ──────────────────────────────────────────────────────
# Challenge mode: cookie, javascript, captcha, recaptcha
BW_USE_ANTIBOT=cookie

# ── Real IP ──────────────────────────────────────────────────────
# Trust proxy headers from these ranges (default: any)
BW_USE_REAL_IP=yes
BW_REAL_IP_FROM=0.0.0.0/0

# ── Threat Intelligence ──────────────────────────────────────────
# Use BunkerNet for real-time threat data
BW_USE_BUNKERNET=yes
BW_USE_BLACKLIST=yes
BW_USE_WHITELIST=yes

# ── Rate Limiting ────────────────────────────────────────────────
# Rate limit settings (requests per second)
BW_USE_LIMIT_REQ=yes
BW_LIMIT_REQ_RATE=10r/s
BW_LIMIT_REQ_BURST=20

# ── Compression ──────────────────────────────────────────────────
# Enable gzip compression
BW_USE_GZIP=yes

# ── Logging ──────────────────────────────────────────────────────
BW_LOG_LEVEL=info

# ── Admin Credentials ────────────────────────────────────────────
BW_ADMIN_USERNAME=admin
BW_ADMIN_PASSWORD=changeme
