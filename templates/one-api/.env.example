# ── One API Configuration ──────────────────────────────────────────────────
# Copy this file to .env and adjust values as needed.

# Host port to expose the One API dashboard and proxy on (default: 3000)
ONE_API_PORT=3000

# Database DSN — defaults to SQLite (one-api.db) if left as-is
# For MySQL: SQL_DSN=root:password@tcp(localhost:3306)/one-api
SQL_DSN=one-api.db

# Session secret — required for production. Generate with:
#   openssl rand -hex 32
SESSION_SECRET=

# Enable logging SQL queries (set to true for debugging)
LOG_SQL_DSN=false

# Batch update interval in seconds for channel updates (default: 5)
BATCH_UPDATE_INTERVAL=5

# UI theme (default, berry, or air)
THEME=default

# Timezone
TZ=UTC
