# ── AgentField Configuration ────────────────────────────────────
# Copy this file to .env and adjust values as needed.

# AgentField is a Python library for multi-agent simulation and training.
# This Docker template provides a minimal API wrapper that documents
# the framework nature and provides health/info endpoints.
# See README.md for full pip install usage instructions.

# AgentField API port (default: 8080)
AGENTFIELD_PORT=8080
