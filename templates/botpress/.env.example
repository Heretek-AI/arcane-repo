# ── Botpress Configuration ──────────────────────────────────────────
# Copy this file to .env and adjust values as needed.

# ── ⚠️  REQUIRED ⚠️  ──────────────────────────────────────────────
# Database credentials (generate strong passwords):
#   openssl rand -hex 32
DB_USER=botpress
DB_PASSWORD=change-me-to-a-strong-password
DB_NAME=botpress

# ── Ports ─────────────────────────────────────────────────────────
# Botpress UI/API port (default: 3000)
BOTPRESS_PORT=3000

# Host port for PostgreSQL (default: 5432)
BOTPRESS_DB_PORT=5432

# ── Application Settings ──────────────────────────────────────────
# Set to true for production deployments
BP_PRODUCTION=true

# Public URL where Botpress is accessible (for webhook callbacks)
EXTERNAL_URL=http://localhost:3000

# Bind address (default: 0.0.0.0 — all interfaces)
BP_SERVER_HOST=0.0.0.0

# ── Pro / Enterprise (Optional) ───────────────────────────────────
# License key for Botpress Pro or Enterprise features
BP_LICENSE_KEY=
