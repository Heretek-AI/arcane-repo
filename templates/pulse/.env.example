# ── Pulse Configuration ───────────────────────────────────────────
# Copy this file to .env and adjust values as needed.

# ── Service Port ──────────────────────────────────────────────────
# Host port for Pulse application (default: 8080)
PULSE_PORT=8080

# ── Database ──────────────────────────────────────────────────────
# PostgreSQL database name
PULSE_DB_NAME=pulse

# PostgreSQL user
PULSE_DB_USER=pulse

# PostgreSQL password (change this!)
PULSE_DB_PASSWORD=changeme

# ── Security ──────────────────────────────────────────────────────
# Secret key for session encryption (generate a random string)
PULSE_SECRET_KEY=

# ── Logging ───────────────────────────────────────────────────────
# Log level: debug, info, warning, error
PULSE_LOG_LEVEL=info
