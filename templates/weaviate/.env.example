# ── Weaviate Configuration ─────────────────────────────────────────────
# Copy this file to .env and adjust values as needed.

# Host port to expose the Weaviate API on (default: 8080)
WEAVIATE_PORT=8080

# Enable anonymous access (default: true)
# Set to false and configure an API key or OIDC for production
AUTHENTICATION_ANONYMOUS_ACCESS_ENABLED=true

# Cluster hostname for multi-node setups (default: weaviate-node-0)
CLUSTER_HOSTNAME=weaviate-node-0

# Default vectorizer module (default: none)
# Options: text2vec-cohere, text2vec-huggingface, text2vec-openai, text2vec-ollama, none
DEFAULT_VECTORIZER_MODULE=none

# ── Modules ─────────────────────────────────────────────────────────
# Comma-separated list of vectorizer and generative modules to enable.
ENABLE_MODULES=text2vec-cohere,text2vec-huggingface,text2vec-openai,text2vec-ollama,generative-openai,generative-cohere,generative-ollama,qna-openai
