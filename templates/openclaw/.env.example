# ── OpenClaw Configuration ─────────────────────────────────────────────────
# Copy this file to .env and adjust values as needed.
#
# OpenClaw is a foundation template for a community/event platform API server.
# Use this as a starting point for your own service — adjust variables,
# add new ones, and extend as needed.

# ── API Server ─────────────────────────────────────────────────────────────
# Host port for the API server (default: 3000)
API_PORT=3000

# Node environment (development, production, test)
NODE_ENV=development

# ── Database ───────────────────────────────────────────────────────────────
# PostgreSQL superuser password (required)
POSTGRES_PASSWORD=change-me-to-a-strong-password

# PostgreSQL database name (default: openclaw)
POSTGRES_DB=openclaw

# PostgreSQL user name (default: openclaw)
POSTGRES_USER=openclaw

# Host port for PostgreSQL (default: 5432)
POSTGRES_PORT=5432

# ── Authentication (Required) ──────────────────────────────────────────────
# JWT secret key for signing and verifying authentication tokens.
# Generate a strong key before first run:
#   openssl rand -hex 32
JWT_SECRET=change-me-to-a-random-64-hex-char-string
