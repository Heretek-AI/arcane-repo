# ── Meetily Configuration ──────────────────────────────────────────
# Copy this file to .env and adjust values as needed.

# Meetily is primarily a desktop Electron application.
# This Docker template provides a minimal API wrapper that documents
# the desktop-only nature and provides a health check endpoint.
# See README.md for desktop app installation instructions.

# Meetily API port (default: 8000)
MEETILY_PORT=8000
