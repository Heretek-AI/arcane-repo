# ── Bishêng Configuration ───────────────────────────────────────────
# Copy this file to .env and adjust values as needed.

# ── ⚠️  REQUIRED ⚠️  ──────────────────────────────────────────────
# Database credentials (generate strong passwords):
#   openssl rand -hex 32
DB_USER=bisheng
DB_PASSWORD=change-me-to-a-strong-password
DB_NAME=bisheng

# Redis password (optional, defaults to "bishengredis")
REDIS_PASSWORD=bishengredis

# ── Ports ─────────────────────────────────────────────────────────
# Bishêng backend API port (default: 9001)
BISHENG_BACKEND_PORT=9001

# Bishêng frontend UI port (default: 3000)
BISHENG_FRONTEND_PORT=3000

# Host port for PostgreSQL (default: 5432)
BISHENG_DB_PORT=5432

# ── LLM Configuration ─────────────────────────────────────────────
# Default model for inference (leave empty if using Ollama):
OPENAI_API_KEY=

# For local inference via Ollama:
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Default model to use for completions (e.g., gpt-4o, llama3)
LLM_MODEL=

# ── Application Settings ──────────────────────────────────────────
# Bishêng license key (optional, leave empty for community edition)
BISHENG_LICENSE=

# Log level: debug, info, warning, error
LOG_LEVEL=info
