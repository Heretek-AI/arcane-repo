# Flagsmith — open-source feature flag & remote config platform
# Copy to .env and configure before starting

# ── Required ───────────────────────────────────────────────────────────

# Database credentials
FLAGSMITH_DB_USER=flagsmith
FLAGSMITH_DB_PASSWORD=your-secure-db-password
FLAGSMITH_DB_NAME=flagsmith

# Django secret key — generate with: openssl rand -hex 32
FLAGSMITH_SECRET_KEY=replace-with-openssl-rand-hex-32

# ── Admin Setup ────────────────────────────────────────────────────────

# Initial admin login (used on first startup only or when resets needed)
FLAGSMITH_ADMIN_EMAIL=admin@example.com
FLAGSMITH_ADMIN_PASSWORD=changeme

# ── Optional ───────────────────────────────────────────────────────────

# Allow open registration (set to "false" to require invitations)
FLAGSMITH_ALLOW_OPEN_REGISTRATION=true

# Prevent new signups entirely
FLAGSMITH_PREVENT_SIGNUP=false

# SMTP for email notifications (password resets, invitations, etc.)
FLAGSMITH_SMTP_HOST=
FLAGSMITH_SMTP_PORT=587
FLAGSMITH_SMTP_USER=
FLAGSMITH_SMTP_PASSWORD=
FLAGSMITH_SMTP_USE_TLS=true
FLAGSMITH_FROM_EMAIL=noreply@example.com

# ── Host Port ──────────────────────────────────────────────────────────

FLAGSMITH_PORT=8000
