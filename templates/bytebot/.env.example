# ── Bytebot Configuration ──────────────────────────────────────
# Copy this file to .env and adjust values as needed.

# Bytebot is a Python browser automation library and CLI.
# No public Docker image or upstream Dockerfile exists.
# This Docker template provides a minimal API wrapper that documents
# the library nature and provides health/info endpoints.
# See README.md for pip install and Python usage instructions.

# Bytebot API stub port (default: 8000)
BYTEBOT_PORT=8000
