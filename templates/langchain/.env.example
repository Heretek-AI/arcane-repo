# ── LangChain / LangServe Configuration ─────────────────────────────────────
# Copy this file to .env and adjust values as needed.

# ── LLM Provider API Key (Required) ────────────────────────────────────────
# The LangServe server needs access to an LLM provider. Set your API key
# for the model provider you intend to use.
#
# OpenAI (default):
#   Generate an API key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-api-key-here

# Model to use for chat completions (default: gpt-4o-mini)
# Supported models depend on your configured provider:
#   OpenAI:      gpt-4o, gpt-4o-mini, gpt-4-turbo, etc.
#   Anthropic:   claude-3-5-sonnet-20241022 (requires ANTHROPIC_API_KEY in app)
#   Ollama:      llama3.1:8b (requires local Ollama and langchain-ollama)
MODEL_NAME=gpt-4o-mini

# Port to expose the LangServe API on (default: 8000)
LANGCHAIN_PORT=8000

# ── LangSmith Tracing (Optional) ──────────────────────────────────────────
# Enable LangSmith observability by setting EITHER:
#   1. LANGCHAIN_API_KEY + LANGCHAIN_PROJECT (recommended)
#   2. LANGCHAIN_ENDPOINT + LANGCHAIN_TRACING_V2 (self-hosted)
#
# Get a LangSmith API key at https://smith.langchain.com
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=Arcane-LangServe
