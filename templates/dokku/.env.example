# ── Dokku Configuration ──────────────────────────────────────────
# Copy this file to .env and adjust values as needed.
#
# IMPORTANT: Dokku is a host-level PaaS — NOT deployable via
# docker compose up. The bootstrap.sh process configures SSH,
# nginx, and the host OS. This template provides an informational
# API stub that documents dokku and how to install it.
#
# To install dokku on your host OS:
#   wget -qO- https://dokku.com/install/v0.35.15/bootstrap.sh | sudo bash
#
# See README.md for full installation instructions and requirements.

# Informational API port (default: 8000)
DOKKU_PORT=8000
