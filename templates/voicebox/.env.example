# ── Voicebox AI Configuration ──────────────────────────────────
# Copy this file to .env and adjust values as needed.

# Voicebox AI provides speech synthesis and voice cloning. Due to
# GPU requirements and model download sizes, this Docker template
# provides a minimal informational API wrapper. For full functionality:
#   pip install voicebox-ai
#   voicebox serve
# See README.md for details.

# Voicebox API port (default: 8000)
VOICEBOX_PORT=8000
