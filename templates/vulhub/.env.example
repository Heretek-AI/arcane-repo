# ── Vulhub Configuration ──────────────────────────────────────
# Copy this file to .env and adjust values as needed.

# Vulhub is a collection of ~200 vulnerable-environment Docker Compose
# files, not a deployable Docker image. This template runs an informational
# API that catalogs the upstream resources.
# See README.md for full native usage instructions (git clone + compose up).

# Vulhub API port (default: 8000)
VULHUB_PORT=8000
