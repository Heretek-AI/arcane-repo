# ── Trivy Configuration ─────────────────────────────────────────
# Copy this file to .env and adjust values as needed.

# ── Cache Directory ──────────────────────────────────────────────
# Path inside the container for vulnerability DB cache
TRIVY_CACHE_DIR=/root/.cache/trivy

# ── Output Control ───────────────────────────────────────────────
# Suppress progress output (default: false)
TRIVY_QUIET=false

# ── Debug Mode ───────────────────────────────────────────────────
# Enable debug logging (default: false)
TRIVY_DEBUG=false

# ── Severity Filter ──────────────────────────────────────────────
# Comma-separated list of severities: UNKNOWN,LOW,MEDIUM,HIGH,CRITICAL
TRIVY_SEVERITY=CRITICAL,HIGH,MEDIUM

# ── Scan Timeout ─────────────────────────────────────────────────
# Maximum duration for a scan (default: 5m0s)
TRIVY_TIMEOUT=5m0s
