# ── Sunshine Game Streaming Host ─────────────────────────────────
# Copy this file to .env and adjust values as needed.

# ── User / Group ─────────────────────────────────────────────────
# User/group IDs for the sunshine process (default: 1000)
SUNSHINE_UID=1000
SUNSHINE_GID=1000

# ── Timezone ─────────────────────────────────────────────────────
SUNSHINE_TZ=UTC
