# ── Pulse Configuration ────────────────────────────────────────────────────
# Copy this file to .env and adjust values as needed.

# Host port for the Pulse web dashboard (default: 8080)
PULSE_PORT=8080

# PostgreSQL database name
PULSE_DB_NAME=pulse

# PostgreSQL database user
PULSE_DB_USER=pulse

# PostgreSQL database password — CHANGE THIS in production
PULSE_DB_PASSWORD=changeme

# Secret key for session encryption — required for production
# Generate with: openssl rand -hex 32
PULSE_SECRET_KEY=

# Log level: debug, info, warn, error
PULSE_LOG_LEVEL=info
