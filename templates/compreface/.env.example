# ── CompreFace Configuration ──────────────────────────────────────
# Copy this file to .env and adjust values as needed.

# ── Service Port ──────────────────────────────────────────────────
# Host port for CompreFace REST API (default: 8000)
COMPREFACE_PORT=8000

# ── Database ──────────────────────────────────────────────────────
# PostgreSQL database name
COMPREFACE_DB=compreface

# PostgreSQL user
COMPREFACE_DB_USER=compreface

# PostgreSQL password (change this!)
COMPREFACE_DB_PASSWORD=changeme

# ── JVM Options ───────────────────────────────────────────────────
# Java heap and tuning options
COMPREFACE_JAVA_OPTS=-Xms512m -Xmx2g
