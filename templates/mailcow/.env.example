# ── Mailcow Configuration ──────────────────────────────────────
# Copy this file to .env and adjust values as needed.

# Mailcow IS a docker-compose repository (mailcow/mailcow-dockerized).
# Adding another compose wrapper would be circular.
# This Docker template provides a minimal API wrapper that documents
# the circular dependency and provides health/info endpoints.
# Clone the upstream repo directly for full functionality.

# Mailcow API stub port (default: 8000)
MAILCOW_PORT=8000
