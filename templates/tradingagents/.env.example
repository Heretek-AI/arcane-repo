# TradingAgents environment configuration
# Copy to .env and customize for your setup

# Service port (FastAPI wrapper)
TRADINGAGENTS_PORT=8000

# LLM provider API keys (at least one required)
OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=
DEEPSEEK_API_KEY=

# Data source (required for market data)
ALPHA_VANTAGE_API_KEY=
