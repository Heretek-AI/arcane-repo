# ── Midscene Configuration ──────────────────────────────────────────
# Copy this file to .env and adjust values as needed.

# ── API Keys ───────────────────────────────────────────────────────
# Midscene is primarily a CLI/testing tool. This thin API wrapper
# provides a health check and example endpoint for Docker deployment.
# See README.md for CLI usage instructions.

# Midscene API port (default: 8000)
MIDSCENE_PORT=8000

# OpenAI API key — required for Midscene's AI-driven UI analysis
# Get yours at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Puppeteer/Playwright execution timeout in ms (default: 30000)
MIDSCENE_TIMEOUT=30000
