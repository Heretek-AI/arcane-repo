# =============================================================================
# WGCloud — Environment Configuration
# Java Spring Boot distributed monitoring system
# =============================================================================

# Host port for MySQL database (default: 3306)
MYSQL_PORT=3306

# Host port for WGCloud server (default: 9999)
WGCLOUD_PORT=9999

# MySQL root password (required — set this before first start)
# MYSQL_ROOT_PASSWORD=changeme

# MySQL database name (default: wgcloud, matches upstream SQL schema)
# MYSQL_DATABASE=wgcloud
