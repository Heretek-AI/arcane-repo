# ── Dokploy Configuration ─────────────────────────────────────────
# Copy this file to .env and adjust values as needed.

# ── Service Port ──────────────────────────────────────────────────
# Host port for Dokploy web dashboard (default: 3000)
DOKPLOY_PORT=3000

# ── Runtime ───────────────────────────────────────────────────────
# Node.js environment mode: production, development
DOKPLOY_NODE_ENV=production

# ── Security ──────────────────────────────────────────────────────
# Secret key for session encryption (generate a random string)
DOKPLOY_SECRET_KEY=

# ── Docker Integration ────────────────────────────────────────────
# To enable Docker container management from the dashboard, uncomment
# the docker.sock volume mount in docker-compose.yml. This gives the
# container access to the host's Docker daemon.
