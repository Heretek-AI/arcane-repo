# ── Pathway Configuration ──────────────────────────────────────────────────
# Copy this file to .env and adjust values as needed.

# Host port for the Pathway REST API and dashboard (default: 8000)
PATHWAY_PORT=8000

# Listen address inside the container
PATHWAY_HOST=0.0.0.0

# Persistent storage directory for indexed data
PATHWAY_PERSISTENT_STORAGE=/app/data

# Pathway license key (use "demo" for evaluation)
PATHWAY_LICENSE_KEY=demo

# OpenAI API key — required for LLM-powered RAG and embeddings
PATHWAY_OPENAI_API_KEY=

# Log level: DEBUG, INFO, WARNING, ERROR
PATHWAY_LOG_LEVEL=INFO
