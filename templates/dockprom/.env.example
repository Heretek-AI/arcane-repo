# ── dockprom Configuration ────────────────────────────────────────
# Copy this file to .env and adjust values as needed.
# Upstream: https://github.com/stefanprodan/dockprom

# ── Grafana ───────────────────────────────────────────────────────
# Host port for Grafana web interface
GRAFANA_PORT=3000

# Admin user credentials
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme

# ── Prometheus ────────────────────────────────────────────────────
# Host port for Prometheus web UI and API
PROMETHEUS_PORT=9090

# Data retention period for Prometheus metrics (default: 15d)
# Accepts: 1d, 30d, 90d, 365d, etc.
PROMETHEUS_RETENTION=15d

# ── AlertManager ──────────────────────────────────────────────────
# Host port for AlertManager web UI and API
ALERTMANAGER_PORT=9093

# ── Pushgateway ───────────────────────────────────────────────────
# Host port for Pushgateway API
PUSHGATEWAY_PORT=9091

# ── cAdvisor ──────────────────────────────────────────────────────
# Host port for cAdvisor container metrics UI
CADVISOR_PORT=8080

# ── Caddy ─────────────────────────────────────────────────────────
# HTTP port for the Caddy reverse proxy (serves Grafana, Prometheus, AlertManager)
CADDY_HTTP_PORT=80
