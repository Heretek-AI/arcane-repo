# Plexe environment configuration
# Copy to .env and customize for your setup

# Service port (FastAPI wrapper)
PLEXE_PORT=8000

# LLM API keys (required — Plexe uses LiteLLM for multi-provider support)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Data & work directory mounts
PLEXE_DATA_DIR=./data
PLEXE_WORKDIR=./workdir
