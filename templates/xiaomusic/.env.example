# ── Xiaomusic Configuration ──────────────────────────────────────
# Copy this file to .env and adjust values as needed.
#
# Xiaomusic is a Xiaomi smart speaker music player with LLM integration.
# This is a custom-build template — the Docker image is built from source.
# Set your Xiaomi account credentials below.

# Xiaomi account credentials (required)
XIAOMUSIC_MI_USER=your_xiaomi_account_id
XIAOMUSIC_MI_PASSWORD=your_xiaomi_password
XIAOMUSIC_MI_DID=your_device_id
XIAOMUSIC_MI_HARDWARE=your_hardware_model

# Ports
XIAOMUSIC_WEB_PORT=8090
XIAOMUSIC_HEALTH_PORT=8091

# Timezone
TZ=Asia/Shanghai

# Data directories
XIAOMUSIC_CONF_DIR=./conf
XIAOMUSIC_MUSIC_DIR=./music
