# Docker IPSec VPN Server — self-hosted IPsec/L2TP VPN
# Copy to .env and configure BEFORE starting
#
# WARNING: These credentials protect ALL VPN access.
# Use strong, unique values — never reuse passwords.

# ── Required ───────────────────────────────────────────────────────────

# IPsec Pre-Shared Key (must match on all clients — strong random string)
VPN_IPSEC_PSK=replace-with-a-strong-random-string

# VPN Username
VPN_USER=vpnuser

# VPN Password
VPN_PASSWORD=replace-with-a-strong-password

# ── Optional ───────────────────────────────────────────────────────────

# VPN DNS servers (default: Google)
VPN_DNS_SRV1=8.8.8.8
VPN_DNS_SRV2=8.8.4.4

# Workaround for Windows 10/11 SHA2 truncation bug (set to "no" if clients use Windows without KB500xxxx updates)
VPN_SHA2_TRUNCBUG=yes
