# ── Page Agent Configuration ──────────────────────────────────────
# Copy this file to .env and adjust values as needed.

# Page Agent is primarily a Node.js in-browser GUI agent tool.
# This Docker template provides a minimal API wrapper that documents
# the CLI-tool nature and provides health/info endpoints.
# See README.md for full CLI usage instructions.

# Page Agent API port (default: 8000)
PAGE_AGENT_PORT=8000
