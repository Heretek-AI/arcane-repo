# ── Jina Configuration ─────────────────────────────────────────────────────
# Copy this file to .env and adjust values as needed.

# Host port for the Jina gateway API (default: 8080)
JINA_GATEWAY_PORT=8080

# Communication protocol between gateway and executor (grpc, http, websocket)
JINA_PROTOCOL=grpc

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
JINA_LOG_LEVEL=INFO
