# ── TypeSense Configuration ──────────────────────────────────────────
# Copy this file to .env and adjust values as needed.

# ── ⚠️  API KEY — REQUIRED ⚠️  ──────────────────────────────────────
# TypeSense requires an API key for all requests. Generate a strong
# random string before first run:
#   openssl rand -hex 32
TYPESENSE_API_KEY=change-me-to-a-random-64-char-hex-string

# Host port to expose the TypeSense API on (default: 8108)
TYPESENSE_PORT=8108

# Enable CORS headers for browser-based requests (default: true)
TYPESENSE_ENABLE_CORS=true
