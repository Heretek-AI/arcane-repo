# ── RedInk Configuration ──────────────────────────────────────────
# Copy this file to .env and adjust values as needed.

# ── Service Port ──────────────────────────────────────────────────
# Host port for RedInk (default: 12398)
REDINK_PORT=12398

# ── Security ──────────────────────────────────────────────────────
# Secret key for session encryption (generate a random string)
REDINK_SECRET_KEY=

# ── Database ──────────────────────────────────────────────────────
# Database URL (default: SQLite at /app/data/redink.db)
REDINK_DB_URL=sqlite:///app/data/redink.db

# ── LLM Provider ──────────────────────────────────────────────────
# Provider: openai, anthropic, local, ollama
REDINK_API_PROVIDER=openai

# API key for the selected provider
REDINK_API_KEY=

# Custom API base URL (leave empty for default)
REDINK_API_BASE_URL=

# Model name (default: gpt-4)
REDINK_MODEL_NAME=gpt-4

# ── Image Generation ──────────────────────────────────────────────
# API key for image generation (uses same provider if not set)
REDINK_IMAGE_API_KEY=

# ── Logging ───────────────────────────────────────────────────────
# Log level: debug, info, warning, error
REDINK_LOG_LEVEL=info

# ── Timezone ──────────────────────────────────────────────────────
TZ=UTC
