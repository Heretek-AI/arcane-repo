# ── TensorZero Configuration ────────────────────────────────────────
# Copy this file to .env and adjust values as needed.

# Host port to expose the TensorZero gateway on (default: 3000)
TENSORZERO_PORT=3000

# ── Inference Providers ────────────────────────────────────────────
# At least one API key is required for the gateway to work.
# Set only the providers you plan to use.

# OpenAI
OPENAI_API_KEY=

# Anthropic
ANTHROPIC_API_KEY=

# Google / Gemini
GOOGLE_API_KEY=

# AWS Bedrock
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# ── Local Inference ────────────────────────────────────────────────
# For Ollama running on the host machine (or at a custom URL)
OLLAMA_BASE_URL=http://host.docker.internal:11434

# ── Gateway Config ────────────────────────────────────────────────
# Path to the TensorZero gateway configuration file (default: /app/config/tensorzero.toml)
# TENSORZERO_CONFIG_FILE=/app/config/tensorzero.toml

# ── Observability (Optional) ──────────────────────────────────────
# ClickHouse URL for storing inference logs and metrics.
# If empty, TensorZero logs to stdout only.
TENSORZERO_CLICKHOUSE_URL=
