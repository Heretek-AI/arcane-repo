# ── LangGraph Configuration ──────────────────────────────────────
# Copy this file to .env and adjust values as needed.

# LangGraph is a Python framework for building stateful multi-actor agents.
# This Docker template provides a minimal API wrapper that documents
# the framework nature and provides health/info endpoints.
# See README.md for full pip install usage instructions.

# LangGraph API port (default: 8000)
LANGGRAPH_PORT=8000
