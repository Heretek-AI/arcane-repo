# ── Microsandbox Configuration ─────────────────────────────────────────────
# Copy this file to .env and adjust values as needed.

# Data directory for sandbox images and state
MICROSANDBOX_DATA_DIR=/var/lib/microsandbox

# Socket directory for sandbox communication
MICROSANDBOX_SOCKET_DIR=/var/run/microsandbox

# Default OS image for new sandboxes
MICROSANDBOX_DEFAULT_IMAGE=alpine

# Default memory limit per sandbox in MB
MICROSANDBOX_MEMORY_MB=512

# Default CPU count per sandbox
MICROSANDBOX_CPU_COUNT=1

# Default execution timeout in seconds
MICROSANDBOX_TIMEOUT_SEC=30

# Log level: debug, info, warn, error
MICROSANDBOX_LOG_LEVEL=info
