# ── CompreFace Configuration ───────────────────────────────────────────────
# Copy this file to .env and adjust values as needed.

# Host port for the CompreFace REST API (default: 8000)
COMPREFACE_PORT=8000

# PostgreSQL database name
COMPREFACE_DB=compreface

# PostgreSQL database user
COMPREFACE_DB_USER=compreface

# PostgreSQL database password — CHANGE THIS in production
COMPREFACE_DB_PASSWORD=changeme

# Java heap memory options for the API service
COMPREFACE_JAVA_OPTS=-Xms512m -Xmx2g
