# UNIT3D — self-hosted private torrent tracker
# Copy to .env and configure before starting

# ── Required ───────────────────────────────────────────────────────────

# Laravel application key — REQUIRED, container refuses to start without it
# Generate with: head -c 32 /dev/urandom | base64
APP_KEY=

# Database credentials
DB_DATABASE=unit3d
DB_USERNAME=unit3d
DB_PASSWORD=change-me-db-password

# MySQL root password (used for healthcheck and initial setup)
MYSQL_ROOT_PASSWORD=change-me-root-password

# ── Optional — Application ─────────────────────────────────────────────

# Public URL where UNIT3D will be accessible (used for asset URLs, redirects)
APP_URL=http://localhost

# ── Optional — Meilisearch ─────────────────────────────────────────────

# Meilisearch master key (must match between app and meilisearch service)
MEILISEARCH_KEY=unit3d-meili-master-key

# ── Host Port ──────────────────────────────────────────────────────────

# Host port mapped to the UNIT3D web UI (container listens on 8000)
UNIT3D_PORT=80
