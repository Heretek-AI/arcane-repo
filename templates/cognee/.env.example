# ── Cognee Configuration ────────────────────────────────────────────
# Copy this file to .env and adjust values as needed.

# ── ⚠️  LLM API KEY — REQUIRED ⚠️  ──────────────────────────────────
# Cognee requires an LLM for knowledge graph extraction and querying.
# Get an OpenAI API key at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# LLM model for graph extraction and chat (default: gpt-4o-mini)
COGNEE_LLM_MODEL=gpt-4o-mini

# Embedding model for vector storage (default: text-embedding-3-small)
COGNEE_EMBEDDING_MODEL=text-embedding-3-small

# Host port to expose the Cognee API on (default: 8000)
COGNEE_PORT=8000

# ── Optional: External Graph Database ───────────────────────────────
# By default, Cognee uses embedded SQLite for graph storage.
# For production, configure a Neo4j database:
# COGNEE_GRAPH_DATABASE_URL=bolt://localhost:7687
# COGNEE_GRAPH_DATABASE_USER=neo4j
# COGNEE_GRAPH_DATABASE_PASSWORD=your-password

# ── Optional: External Vector Store ─────────────────────────────────
# By default, Cognee uses embedded LanceDB. For production,
# configure Qdrant, Weaviate, or another vector store:
# COGNEE_VECTOR_DATABASE_URL=http://localhost:6333
