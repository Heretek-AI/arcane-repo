# ── ElizaOS Configuration ──────────────────────────────────────────
# Copy this file to .env and adjust values as needed.

# ── Ports ─────────────────────────────────────────────────────────
# ElizaOS API port (default: 3000)
ELIZAOS_PORT=3000

# ── LLM Provider (at least one required) ──────────────────────────
# OpenAI
OPENAI_API_KEY=

# Anthropic
ANTHROPIC_API_KEY=

# Google Gemini
GOOGLE_GEMINI_API_KEY=

# ── Agent Configuration ──────────────────────────────────────────
# Character definition (optional — runs default character if empty)
# Can be a character name or path relative to the characters directory
ELIZA_CHARACTER=

# ── Application Settings ──────────────────────────────────────────
# Log level: debug, info, warning, error
LOG_LEVEL=info

# Node environment
NODE_ENV=production
