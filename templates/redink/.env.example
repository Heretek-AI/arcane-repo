# ── RedInk Configuration ───────────────────────────────────────────────────
# Copy this file to .env and adjust values as needed.

# Host port for the RedInk web application (default: 12398)
REDINK_PORT=12398

# Secret key for Flask session encryption — required for production
# Generate with: openssl rand -hex 32
REDINK_SECRET_KEY=

# Database URL — SQLite by default, PostgreSQL supported
# For PostgreSQL: postgresql://user:pass@host:5432/redink
REDINK_DB_URL=sqlite:///app/data/redink.db

# LLM API provider (openai, azure, anthropic, custom)
REDINK_API_PROVIDER=openai

# API key for the LLM provider
REDINK_API_KEY=

# Custom API base URL (for Azure, local proxies, etc.)
REDINK_API_BASE_URL=

# Model name to use for text generation
REDINK_MODEL_NAME=gpt-4

# API key for image generation (DALL-E, Stable Diffusion, etc.)
REDINK_IMAGE_API_KEY=

# Log level: debug, info, warn, error
REDINK_LOG_LEVEL=info

# Timezone
TZ=UTC
