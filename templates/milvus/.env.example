# ── Milvus Configuration ─────────────────────────────────────────────
# Copy this file to .env and adjust values as needed.

# Host port for the Milvus gRPC API (default: 19530)
MILVUS_PORT=19530

# ── ETCD (Metadata Store) ────────────────────────────────────────────
# Host port for the etcd client API (default: 2379)
ETCD_PORT=2379

# Host port for etcd peer communication (default: 2380)
ETCD_PEER_PORT=2380

# Set to false when using external etcd (defined in docker-compose.yml)
ETCD_USE_EMBED=false

# ── MinIO (Object Storage) ───────────────────────────────────────────
# Host port for the MinIO S3-compatible API (default: 9000)
MINIO_PORT=9000

# Host port for the MinIO web console (default: 9001)
MINIO_CONSOLE_PORT=9001

# MinIO root credentials (default: minioadmin / minioadmin)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ── ETCD Endpoints (for multi-node etcd, comma-separated) ────────────
# Default points to the etcd container defined in docker-compose.yml
ETCD_ENDPOINTS=milvus-etcd:2379

# MinIO address for Milvus to connect to
MINIO_ADDRESS=milvus-minio:9000

# Common storage type (default: minio)
COMMON_STORAGETYPE=minio
