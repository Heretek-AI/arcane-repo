# Host port for Clawith web UI (backend API + frontend SPA)
CLAWITH_PORT=8000

# PostgreSQL configuration
POSTGRES_DB=clawith
POSTGRES_USER=clawith
POSTGRES_PASSWORD=clawith

# Security keys (CHANGE THESE in production)
SECRET_KEY=change-me-in-production
JWT_SECRET_KEY=change-me-jwt-secret

# CORS origins (comma-separated or JSON array)
CORS_ORIGINS='["*"]'

# Public base URL for OAuth callbacks and email links
PUBLIC_BASE_URL=http://localhost:8000

# Optional: Feishu integration
# FEISHU_APP_ID=
# FEISHU_APP_SECRET=
