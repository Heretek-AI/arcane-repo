# ── RustScan Configuration ──────────────────────────────────────
# Copy this file to .env and adjust values as needed.

# ── Batch Size ───────────────────────────────────────────────────
# Number of ports to scan simultaneously (default: 4500)
# Lower this to ~500 if running without CAP_NET_RAW (TCP connect mode)
RUSTSCAN_BATCH_SIZE=4500

# ── Timeout (ms) ─────────────────────────────────────────────────
# Milliseconds to wait for a response before marking port as closed
RUSTSCAN_TIMEOUT=1500

# ── Ulimit ───────────────────────────────────────────────────────
# File descriptor limit — must be >= batch_size (default: 5000)
RUSTSCAN_ULIMIT=5000
