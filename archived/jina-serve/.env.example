# ── Jina AI Serving Configuration ─────────────────────────────────
# Copy this file to .env and adjust values as needed.

# ── Ports ─────────────────────────────────────────────────────────
# Jina Gateway host port (default: 8080)
JINA_GATEWAY_PORT=8080

# ── Protocol ──────────────────────────────────────────────────────
# Communication protocol between gateway and executor: grpc, http, websocket
JINA_PROTOCOL=grpc

# ── Logging ───────────────────────────────────────────────────────
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
JINA_LOG_LEVEL=INFO
