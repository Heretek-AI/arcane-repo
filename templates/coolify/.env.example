# ── Coolify Configuration ─────────────────────────────────────────
# Copy this file to .env and adjust values as needed.
# Upstream: https://github.com/coollabsio/coolify

# ── Coolify App ───────────────────────────────────────────────────
# Host port for the Coolify web dashboard
COOLIFY_PORT=8000

# Application environment (local or production)
COOLIFY_APP_ENV=local

# Application key for session encryption (generate with: openssl rand -hex 32)
COOLIFY_APP_KEY=

# ── Database ──────────────────────────────────────────────────────
# PostgreSQL database name
COOLIFY_DB_NAME=coolify

# PostgreSQL user
COOLIFY_DB_USER=coolify

# PostgreSQL password (change this!)
COOLIFY_DB_PASSWORD=changeme

# ── Redis ─────────────────────────────────────────────────────────
# Redis password for authentication (optional, set if you want auth)
REDIS_PASSWORD=

# ── Soketi (WebSocket Server) ─────────────────────────────────────
# Soketi app ID for authentication
SOKETI_DEFAULT_APP_ID=coolify

# Soketi app key for authentication
SOKETI_DEFAULT_APP_KEY=

# Soketi app secret for authentication
SOKETI_DEFAULT_APP_SECRET=

# Metrics port for Soketi
SOKETI_METRICS_SERVER_PORT=9601

# ── Docker Socket ─────────────────────────────────────────────────
# Uncomment the docker.sock volume mount in docker-compose.yml to
# allow Coolify to manage user containers (required for PaaS features).
# WARNING: Mounting docker.sock gives the container full control over
# your Docker daemon. Review Coolify's security docs before enabling.
