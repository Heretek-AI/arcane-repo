# ── Pathway LLM App Configuration ─────────────────────────────────
# Copy this file to .env and adjust values as needed.

# ── Service Port ──────────────────────────────────────────────────
# Host port for Pathway app (default: 8000)
PATHWAY_PORT=8000

# ── Bind Address ──────────────────────────────────────────────────
# Interface to bind to (default: 0.0.0.0 — all interfaces)
PATHWAY_HOST=0.0.0.0

# ── LLM Provider ──────────────────────────────────────────────────
# OpenAI API key (required for LLM features)
PATHWAY_OPENAI_API_KEY=

# ── License ───────────────────────────────────────────────────────
# Pathway license key (default: demo — free tier)
PATHWAY_LICENSE_KEY=demo

# ── Persistent Storage ────────────────────────────────────────────
# Directory for persistent data (default: /app/data)
PATHWAY_PERSISTENT_STORAGE=/app/data

# ── Logging ───────────────────────────────────────────────────────
# Log level: DEBUG, INFO, WARNING, ERROR
PATHWAY_LOG_LEVEL=INFO
