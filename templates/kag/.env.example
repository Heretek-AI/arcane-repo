# ── KAG Configuration ──────────────────────────────────────────────────
# Copy this file to .env and adjust values as needed.

# ── ⚠️  LLM API KEY — REQUIRED ⚠️  ──────────────────────────────────
# KAG requires an LLM for knowledge graph construction and querying.
# Get an OpenAI API key at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# LLM model for graph reasoning (default: gpt-4o)
OPENAI_MODEL=gpt-4o

# Host port to expose the KAG API on (default: 8000)
KAG_PORT=8000

# Directory for knowledge base storage (default: /app/knowledge)
KAG_KNOWLEDGE_BASE_DIR=/app/knowledge
