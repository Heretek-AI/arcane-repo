# ── PyTorch Serve Configuration ────────────────────────────────────────────
# Copy this file to .env and adjust values as needed.

# Host port for the TorchServe inference API (default: 8080)
TORCHSERVE_INFERENCE_PORT=8080

# Host port for the TorchServe management API (default: 8081)
TORCHSERVE_MANAGEMENT_PORT=8081

# Comma-separated list of models to load on startup, or "all"
# Format: model_name=model_file.mar
TORCHSERVE_MODELS=all

# Service envelope format — used for pre/post-processing
# Options: body, kserve, kservev2
TS_SERVICE_ENVELOPE=body
