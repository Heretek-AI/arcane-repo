# ── Harbor-LLM Configuration ──────────────────────────────────────
# Copy this file to .env and adjust values as needed.
#
# Harbor-LLM requires access to the Docker socket to manage LLM
# containers. Ensure /var/run/docker.sock is available on the host.

# ── Service Port ──────────────────────────────────────────────────
# Host port for Harbor-LLM API (default: 8000)
HARBOR_LLM_PORT=8000
