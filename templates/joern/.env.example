# ── Joern Configuration ───────────────────────────────────────────
# Copy this file to .env and adjust values as needed.

# ── Server ────────────────────────────────────────────────────────
# Run Joern in server mode (default: true). Set to false for CLI mode.
JOERN_SERVER=true

# Port for the REST server (default: 8080)
JOERN_PORT=8080

# JVM heap size and options (default: -Xmx4G)
JOERN_OPTS=-Xmx4G
