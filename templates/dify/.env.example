# ── Dify Configuration ─────────────────────────────────────────────────────
# Copy this file to .env and adjust values as needed.

# ── ⚠️  SECRET KEY — CRITICAL ⚠️  ─────────────────────────────────────────
# SECRET_KEY is used by Dify to encrypt session data, API tokens, and other
# sensitive information. It MUST be set to a strong, fixed value before first
# run. If this value changes after Dify has been used, all existing sessions,
# tokens, and API keys will be invalidated, requiring users to re-login and
# re-create API credentials.
#
# Generate a strong key BEFORE first run:
#   openssl rand -hex 32   # or any 64-character hex string
#
# Set it here and NEVER change it for the same Dify instance.
SECRET_KEY=change-me-to-a-random-64-character-hex-string

# ── Database ───────────────────────────────────────────────────────────────
# PostgreSQL superuser password (required)
POSTGRES_PASSWORD=change-me-to-a-strong-password

# PostgreSQL database name (default: dify)
POSTGRES_DB=dify

# PostgreSQL user name (default: dify)
POSTGRES_USER=dify

# Host port for PostgreSQL (default: 5432)
POSTGRES_PORT=5432

# ── Redis ──────────────────────────────────────────────────────────────────
# Host port for Redis (default: 6379)
REDIS_PORT=6379

# ── Dify API Server ────────────────────────────────────────────────────────
# Host port for the Dify API server (default: 5001)
DIFY_PORT=5001

# Enable debug mode (true/false, default: false)
# Enables detailed error messages and verbose logging — use only for development
DIFY_DEBUG=false

# Initial admin password for first-time setup
# If not set, Dify will prompt for password configuration on first login
INIT_PASSWORD=
