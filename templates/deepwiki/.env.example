# ── DeepWiki Configuration ────────────────────────────────────────
# Copy this file to .env and adjust values as needed.

# ── API Server ────────────────────────────────────────────────────
# API server port (default: 8001). The web UI is on port 3000.
DEEPWIKI_API_PORT=8001

# Next.js UI port (default: 3000)
DEEPWIKI_UI_PORT=3000

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ── LLM Configuration ─────────────────────────────────────────────
# DeepWiki uses OpenAI-compatible APIs for LLM inference and
# embeddings. At minimum, set OPENAI_API_KEY for cloud access or
# point to a local proxy (e.g., Ollama or LiteLLM).
OPENAI_API_KEY=

# Embedding model name (default: text-embedding-3-small)
EMBEDDING_MODEL=text-embedding-3-small
