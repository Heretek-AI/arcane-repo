# Chatwoot — open-source customer engagement platform
# Copy to .env and configure before starting

# ── Required ───────────────────────────────────────────────────────────

# Database credentials
CHATWOOT_DB_USER=chatwoot
CHATWOOT_DB_PASSWORD=your-secure-db-password
CHATWOOT_DB_NAME=chatwoot

# Rails secret key base — generate with: openssl rand -hex 64
CHATWOOT_SECRET_KEY_BASE=replace-with-openssl-rand-hex-64

# ── Optional — SMTP (required for email notifications) ─────────────────

CHATWOOT_SMTP_ADDRESS=smtp.example.com
CHATWOOT_SMTP_PORT=587
CHATWOOT_SMTP_USERNAME=your-smtp-username
CHATWOOT_SMTP_PASSWORD=your-smtp-password
CHATWOOT_SMTP_DOMAIN=example.com
CHATWOOT_MAILER_SENDER=noreply@example.com

# ── Host Port ──────────────────────────────────────────────────────────

CHATWOOT_PORT=3000
