# ── BeeAI Framework Configuration ───────────────────────────────
# Copy this file to .env and adjust values as needed.

# BeeAI Framework by IBM is a Python/TypeScript library for building
# production-ready AI agents. This Docker template provides a minimal
# API wrapper that documents the framework nature and provides
# health/info endpoints.
# See README.md for full pip/npm install usage instructions.

# BeeAI API port (default: 8000)
BEEAI_PORT=8000
