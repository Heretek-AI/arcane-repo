# ── Harness Configuration ─────────────────────────────────────────
# Copy this file to .env and adjust values as needed.

# ── Service Ports ─────────────────────────────────────────────────
# Host port for Harness web UI (default: 3000)
HARNESS_WEB_PORT=3000

# Host port for Harness SSH service (default: 3022)
HARNESS_SSH_PORT=3022

# ── Operation Mode ────────────────────────────────────────────────
# Deployment mode: standalone (single-node) or cluster (multi-node)
HARNESS_MODE=standalone

# ── Security ──────────────────────────────────────────────────────
# Admin password for the web dashboard (change this!)
HARNESS_ADMIN_PASSWORD=changeme

# ── Docker Integration ────────────────────────────────────────────
# To enable Docker-in-Docker for CI/CD pipeline execution, uncomment
# the docker.sock volume mount in docker-compose.yml. This gives the
# container access to the host's Docker daemon.
