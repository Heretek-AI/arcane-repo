# ── TEN Framework Configuration ───────────────────────────────────
# Copy this file to .env and adjust values as needed.

# TEN Framework is a complex C++/GN build system for voice AI agents.
# This Docker template provides a minimal API wrapper that documents
# the recommended development setup and provides health/info endpoints.
# See README.md for full development instructions.

# TEN Framework API port (default: 8000)
TEN_FRAMEWORK_PORT=8000
