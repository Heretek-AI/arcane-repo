# ── Mailu Configuration ──────────────────────────────────────
# Copy this file to .env and adjust values as needed.

# Mailu is a lightweight mail server suite. No public Docker images
# were found on Docker Hub (mailu/ namespace returned 404).
# This Docker template provides a minimal API wrapper that documents
# the missing-image situation and provides health/info endpoints.
# Use the official setup wizard at setup.mailu.io for full deployment.

# Mailu API stub port (default: 8000)
MAILU_PORT=8000
