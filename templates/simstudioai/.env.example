# ── SimStudio AI Configuration ─────────────────────────────────
# Copy this file to .env and adjust values as needed.

# SimStudio AI is a 3D simulation platform for AI agent training
# and evaluation. Due to GPU-accelerated rendering requirements,
# this Docker template provides a minimal informational API wrapper.
# For full functionality, run on GPU-accelerated hardware:
#   pip install simstudio-ai
# See README.md for details.

# SimStudio API port (default: 8000)
SIMSTUDIOAI_PORT=8000
