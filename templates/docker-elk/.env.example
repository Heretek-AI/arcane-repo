# ── Docker ELK Stack Configuration ────────────────────────────────
# Copy this file to .env and adjust values as needed.
# Upstream: https://github.com/deviantony/docker-elk

# ── Elastic Stack Version ─────────────────────────────────────────
# Pinned to a specific version for reproducible deployments.
# Bump this to upgrade all three services together.
ELK_VERSION=8.17.0

# ── Elasticsearch ─────────────────────────────────────────────────
# Heap size (min and max should be equal to avoid resizing overhead)
ES_HEAP_SIZE=1g

# Bootstrap password for the elastic superuser (change this!)
ELASTIC_PASSWORD=changeme

# Host port for Elasticsearch HTTP API
ES_PORT=9200

# ── Logstash ──────────────────────────────────────────────────────
# Host port for Logstash Beats input (Filebeat, Winlogbeat, etc.)
LOGSTASH_BEATS_PORT=5044

# ── Kibana ────────────────────────────────────────────────────────
# Host port for the Kibana web interface
KIBANA_PORT=5601

# Encryption key for Kibana saved objects and session data
# Generate with: openssl rand -hex 32
KIBANA_ENCRYPTION_KEY=

# ── Setup ─────────────────────────────────────────────────────────
# Set to 'true' to run the one-time setup container on next compose up.
# The setup container exits after completing initialization.
RUN_SETUP=true
