# ── AionUi Configuration ───────────────────────────────────────────
# Copy this file to .env and adjust values as needed.

# Host port to expose the AionUi web interface on (default: 3000)
AIONUI_PORT=3000

# ── API Keys ───────────────────────────────────────────────────────
# AionUi can connect to various LLM providers through its server.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── OAuth (Optional) ──────────────────────────────────────────────
# Required for authentication features.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Build Configuration ───────────────────────────────────────────
# GitHub repository owner and name for the container image tag.
# Only needed if you forked the repo and build your own images.
REPO_OWNER=heretek-ai
REPO_NAME=arcane-repo
