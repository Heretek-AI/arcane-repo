# Supabase — self-hosted Firebase alternative
# Copy to .env and generate keys before starting

# ── Required ───────────────────────────────────────────────────────────

# PostgreSQL superuser password (must be strong — used by all internal services)
POSTGRES_PASSWORD=your-secure-postgres-password

# JWT secret — generate with: openssl rand -hex 32
JWT_SECRET=your-super-secret-jwt-token-with-at-least-32-chars

# ANON_KEY — generate from JWT_SECRET (see README for generation command)
ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoiYW5vbiIsImlzcyI6InN1cGFiYXNlIiwiaWF0IjoxNzE0MDAwMDAwLCJleHAiOjE4NzE3NjY0MDB9.replace-with-real-token

# SERVICE_ROLE_KEY — generate from JWT_SECRET (see README for generation command)
SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoic2VydmljZV9yb2xlIiwiaXNzIjoic3VwYWJhc2UiLCJpYXQiOjE3MTQwMDAwMDAsImV4cCI6MTg3MTc2NjQwMH0.replace-with-real-token

# Studio dashboard credentials (used to log in to the admin UI)
DASHBOARD_USERNAME=supabase
DASHBOARD_PASSWORD=this_password_is_insecure_and_should_be_updated

# ── Ports (host mappings) ──────────────────────────────────────────────

# Kong API Gateway — Supabase API/Data endpoint
KONG_HTTP_PORT=8000

# Kong Admin API (internal)
KONG_ADMIN_PORT=8001

# Studio admin dashboard
STUDIO_PORT=8082

# ── Optional ───────────────────────────────────────────────────────────

# Logflare API key (for logs in Studio dashboard)
LOGFLARE_API_KEY=api-key
