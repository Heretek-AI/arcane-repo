# ── One API Configuration ─────────────────────────────────────────
# Copy this file to .env and adjust values as needed.

# ── Service Port ──────────────────────────────────────────────────
# Host port for web UI and API (default: 3000)
ONE_API_PORT=3000

# ── Timezone ──────────────────────────────────────────────────────
TZ=UTC

# ── Database ──────────────────────────────────────────────────────
# SQLite path or MySQL/PostgreSQL DSN (default: one-api.db — SQLite)
SQL_DSN=one-api.db

# ── Session ───────────────────────────────────────────────────────
# Secret key for session encryption (generate a random string)
SESSION_SECRET=

# ── Logging ───────────────────────────────────────────────────────
# Enable SQL query logging (default: false)
LOG_SQL_DSN=false

# ── Batch Update Interval ─────────────────────────────────────────
# Interval in seconds for batch price updates (default: 5)
BATCH_UPDATE_INTERVAL=5

# ── Theme ─────────────────────────────────────────────────────────
# UI theme: default, dark, light
THEME=default
