# ── Parseable Configuration ───────────────────────────────────────
# Copy this file to .env and adjust values as needed.

# ── Service Port ──────────────────────────────────────────────────
# Host port for Parseable UI and API (default: 8000)
PARSEABLE_PORT=8000

# ── Authentication ────────────────────────────────────────────────
# Admin username
PARSEABLE_USERNAME=admin

# Admin password (change this!)
PARSEABLE_PASSWORD=changeme
