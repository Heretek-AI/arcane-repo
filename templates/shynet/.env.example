# ── Shynet Configuration ──────────────────────────────────────
# Copy this file to .env and adjust values as needed.

# Shynet is a privacy-friendly Django web analytics platform.
# No public Docker image or upstream Dockerfile exists.
# This Docker template provides a minimal API wrapper that documents
# the missing-image situation and provides health/info endpoints.
# Deploy as a Django application with PostgreSQL for full functionality.

# Shynet API stub port (default: 8000)
SHYNET_PORT=8000
