# ── WeKnora (Tencent AI Assistant) Configuration ──────────────────
# Copy this file to .env and adjust values as needed.

# ── ⚠️  REQUIRED ⚠️  ──────────────────────────────────────────────
# Database credentials (generate strong passwords):
#   openssl rand -hex 32
DB_USER=weknora
DB_PASSWORD=change-me-to-a-strong-password
DB_NAME=weknora

# JWT secret for session tokens (generate with openssl rand -hex 32)
JWT_SECRET=change-me-to-a-random-64-char-hex-string

# Redis password (optional, defaults to "redispass")
REDIS_PASSWORD=redispass

# Redis username (optional, leave empty for default)
REDIS_USERNAME=

# Application log level (maps to GIN_MODE; empty = GIN_MODE=release handles it)
LOG_LEVEL=info

# ── Ports ─────────────────────────────────────────────────────────
# WeKnora app backend port (default: 8080)
WEKNORA_APP_PORT=8080

# WeKnora frontend (NGINX) port (default: 80)
WEKNORA_UI_PORT=80

# Host port for PostgreSQL (default: 5432)
WEKNORA_DB_PORT=5432

# ── LLM Configuration ─────────────────────────────────────────────
# WeKnora uses Ollama for local LLM inference by default.
# Point to your Ollama server (or leave as default for host
# Docker networking):
OLLAMA_BASE_URL=http://host.docker.internal:11434

# ── Application Settings ──────────────────────────────────────────
# Set release for production, debug for development
GIN_MODE=release

# Disable new user registration (set to true for single-user)
DISABLE_REGISTRATION=false

# Language: en (English), zh-CN (Chinese)
WEKNORA_LANGUAGE=en

# Max file upload size in MB
MAX_FILE_SIZE_MB=50
