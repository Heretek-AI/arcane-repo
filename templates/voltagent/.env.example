# ── VoltAgent Configuration ─────────────────────────────────────
# Copy this file to .env and adjust values as needed.

# VoltAgent is a Python library for building autonomous AI workflows.
# This Docker template provides a minimal API wrapper that documents
# the framework nature and provides health/info endpoints.
# See README.md for full pip install usage instructions.

# VoltAgent API port (default: 8000)
VOLTAGENT_PORT=8000
