# ── Yuxi Configuration ────────────────────────────────────────────
# Copy this file to .env and adjust values as needed.

# ── Service Port ──────────────────────────────────────────────────
# Host port for Yuxi API (default: 8000)
YUXI_PORT=8000

# ── Database ──────────────────────────────────────────────────────
# PostgreSQL database name
POSTGRES_DB=yuxi

# PostgreSQL user
POSTGRES_USER=yuxi

# PostgreSQL password (change this!)
POSTGRES_PASSWORD=yuxi
