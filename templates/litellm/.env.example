# ── LiteLLM Docker — Environment Variables ─────────────────────────────────────
# Copy this file to .env and fill in your values.
#   cp .env.example .env

# ── REQUIRED ─────────────────────────────────────────────────────────────────
# Master key for admin access and API authentication.
# IMPORTANT: Change this to a strong, randomly generated secret before deploying!
LITELLM_MASTER_KEY=sk-liteLLM-master-key-change-me

# Salt for encrypting stored credentials.
LITELLM_SALT_KEY=sk-liteLLM-salt-key-change-me

# ── DATABASE (optional) ───────────────────────────────────────────────────────
# Leave blank to use SQLite inside the container (data persists in the litellm_data volume).
# To use PostgreSQL, set the full connection string:
# DATABASE_URL=postgresql://user:password@host:5432/litellm
DATABASE_URL=

# ── PROVIDER API KEYS ────────────────────────────────────────────────────────
# Set at least one. LiteLLM reads these automatically — no config changes needed.
# More providers: https://docs.litellm.ai/docs/providers

# OpenAI (ChatGPT, o1, GPT-4o, etc.)
OPENAI_API_KEY=

# Anthropic (Claude 3.5, Opus, Sonnet, etc.)
ANTHROPIC_API_KEY=

# Google Gemini
GEMINI_API_KEY=

# Azure OpenAI
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_BASE=

# Cohere
COHERE_API_KEY=

# Together AI (Llama, Qwen, DeepSeek, etc.)
TOGETHERAI_API_KEY=

# ── PROXY SETTINGS (optional) ─────────────────────────────────────────────────
# Port exposed on the host (default: 4000)
LITELLM_PORT=4000

# Drop unsupported params from requests to providers
LITELLM_DROP_PARAMS=false

# Max parallel requests
LITELLM_MAX_PARALLEL_REQUESTS=

# Request timeout in seconds
LITELLM_REQUEST_TIMEOUT=60