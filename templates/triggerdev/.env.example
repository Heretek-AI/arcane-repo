# ── Trigger.dev Configuration ──────────────────────────────────────
# Copy this file to .env and adjust values as needed.

# ── ⚠️  REQUIRED SECRETS — Generate each with a strong random value ⚠️
#    openssl rand -hex 32
#
# SESSION_SECRET       — Signs session cookies (min 32 chars)
# MAGIC_LINK_SECRET    — Signs magic link tokens (min 32 chars)
# TRIGGER_SECRET_KEY   — Authenticates your trigger.dev client SDK (any length)
# ENCRYPTION_KEY       — Encrypts sensitive data at rest (min 32 chars)

SESSION_SECRET=change-me-to-a-random-64-char-hex-string
MAGIC_LINK_SECRET=change-me-to-a-random-64-char-hex-string
TRIGGER_SECRET_KEY=change-me-to-a-random-secret-key
ENCRYPTION_KEY=change-me-to-a-random-64-char-hex-string

# ── Database ───────────────────────────────────────────────────────
# The compose file auto-constructs DATABASE_URL from these:
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-to-a-strong-password
POSTGRES_DB=triggerdev

# Exposed host port for PostgreSQL (default: 5432)
POSTGRES_PORT=5432

# ── Application ────────────────────────────────────────────────────
# Port the trigger.dev dashboard and API are served on (default: 3030)
TRIGGERDEV_PORT=3030

# The public URL of your trigger.dev instance (used for magic links)
# Change to your domain in production:
#   APP_ORIGIN=https://trigger.example.com
APP_ORIGIN=http://localhost:3030

# ── Optional: GitHub OAuth ─────────────────────────────────────────
# Set these to enable GitHub login on the dashboard.
# Create an OAuth app at https://github.com/settings/developers
# with callback URL: http://localhost:3030/auth/github/callback
AUTH_GITHUB_CLIENT_ID=
AUTH_GITHUB_CLIENT_SECRET=
