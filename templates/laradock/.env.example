# Nginx HTTP Port
NGINX_PORT=8080

# MySQL Port
MYSQL_PORT=3306

# MySQL root password (CHANGE THIS in production)
MYSQL_ROOT_PASSWORD=rootsecret

# MySQL database name
MYSQL_DATABASE=laradock

# MySQL user
MYSQL_USER=laradock

# MySQL user password (CHANGE THIS in production)
MYSQL_PASSWORD=secret

# Redis Port
REDIS_PORT=6379
