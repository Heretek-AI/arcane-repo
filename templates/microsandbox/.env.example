# ── Microsandbox Configuration ────────────────────────────────────
# Copy this file to .env and adjust values as needed.
#
# Microsandbox is a CLI tool for managing micro-VMs via Firecracker.
# Interact with it via: docker compose exec microsandbox microsandbox --help

# ── Storage ───────────────────────────────────────────────────────
# Data directory for sandbox images and metadata
MICROSANDBOX_DATA_DIR=/var/lib/microsandbox

# Socket directory for VM communication
MICROSANDBOX_SOCKET_DIR=/var/run/microsandbox

# ── Default Image ─────────────────────────────────────────────────
# Default VM image (alpine, ubuntu, custom)
MICROSANDBOX_DEFAULT_IMAGE=alpine

# ── Resource Limits ───────────────────────────────────────────────
# Memory per sandbox in MB (default: 512)
MICROSANDBOX_MEMORY_MB=512

# CPU count per sandbox (default: 1)
MICROSANDBOX_CPU_COUNT=1

# ── Timeout ───────────────────────────────────────────────────────
# Sandbox idle timeout in seconds (default: 30)
MICROSANDBOX_TIMEOUT_SEC=30

# ── Logging ───────────────────────────────────────────────────────
# Log level: debug, info, warning, error
MICROSANDBOX_LOG_LEVEL=info
