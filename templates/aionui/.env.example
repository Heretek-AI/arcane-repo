# ── AionUi Configuration ───────────────────────────────────────────
# Copy this file to .env and adjust values as needed.

# Host port to expose the AionUi web interface on (default: 3000)
AIONUI_PORT=3000

# ── API Keys ───────────────────────────────────────────────────────
# AionUi can connect to various LLM providers through its server.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── OAuth (Optional) ──────────────────────────────────────────────
# Required for authentication features.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
