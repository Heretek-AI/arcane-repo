# ── Tianji Configuration ──────────────────────────────────────────
# Copy this file to .env and adjust values as needed.

# ── Service Port ──────────────────────────────────────────────────
# Host port for Tianji web dashboard (default: 12345)
TIANJI_PORT=12345

# ── Database ──────────────────────────────────────────────────────
# PostgreSQL database name
TIANJI_DB_NAME=tianji

# PostgreSQL user
TIANJI_DB_USER=tianji

# PostgreSQL password (change this!)
TIANJI_DB_PASSWORD=changeme

# ── Security ──────────────────────────────────────────────────────
# JWT secret for session tokens (generate a random string)
TIANJI_JWT_SECRET=

# ── Authentication ────────────────────────────────────────────────
# Allow new user registration (true/false) — set to false after first admin account
TIANJI_ALLOW_REGISTER=true
